---
const pageUrl = Astro.url.href;
---

<div id="remark42"></div>

<script define:vars={{ pageUrl }}>
  var remark_config = {
    host: "https://remark42.natinternet.com",
    site_id: "advancedbiomass",
    url: pageUrl,
    components: ["embed"],
    max_shown_comments: 20,
    theme: "light",
    locale: "en",
  };
</script>
<script async src="https://remark42.natinternet.com/web/embed.js"></script>
